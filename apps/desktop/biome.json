{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"files": {
		"includes": [
			"src/**/*.ts",
			"src/**/*.tsx",
			"src/**/*.d.ts",
			"tsconfig.json"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noArrayIndexKey": "warn"
			},
			"a11y": {
				"noLabelWithoutControl": "warn",
				"useAriaPropsSupportedByRole": "warn",
				"useAriaPropsForRole": "warn",
				"noAutofocus": "warn"
			}
		}
	}
}
