{
  "template_id": "wft-maestro-productization-20260628",
  "name": "Maestro 产品化工作流",
  "description": "把 Maestro-flow 包装成可视化桌面产品，并把重复提取和搬运工作交给低成本模型处理。",
  "version": "1.0",
  "created_at": "2026-06-28T00:00:00Z",
  "source_session": "manual-20260628",
  "tags": ["maestro", "productization", "workflow", "visualization"],
  "context_schema": {
    "goal": {
      "type": "string",
      "required": true,
      "description": "本次要推进的产品化目标"
    },
    "maestro_flow_path": {
      "type": "string",
      "required": true,
      "description": "本地 Maestro-flow 源码路径",
      "default": "D:\\WorkSpace\\Source\\maestro-flow"
    },
    "target_app_path": {
      "type": "string",
      "required": true,
      "description": "本地 Oh My Maestro 桌面应用路径",
      "default": "D:\\WorkSpace\\VsCode\\oh-my-maestro-rebuild\\apps\\desktop"
    },
    "low_cost_model": {
      "type": "string",
      "required": false,
      "description": "用于重复提取和整理工作的模型或工具",
      "default": "DeepSeek/GLM/iFlytek CodePlan"
    }
  },
  "nodes": [
    {
      "id": "N-001",
      "name": "分析产品边界",
      "type": "skill",
      "executor": "maestro-analyze",
      "args_template": "{goal}",
      "input_ports": ["requirement"],
      "output_ports": ["analysis"],
      "parallel_group": null,
      "on_fail": "abort"
    },
    {
      "id": "CP-01",
      "name": "检查点：产品边界",
      "type": "checkpoint",
      "description": "确认 Superset 只作为概念参考，不作为 MVP runtime 依赖。",
      "auto_continue": false,
      "save_fields": ["session_id", "artifacts", "output_path"]
    },
    {
      "id": "N-002",
      "name": "规划命令注册表",
      "type": "skill",
      "executor": "maestro-plan",
      "args_template": "为 Oh My Maestro 设计 typed command registry。上下文：{prev_output_path}",
      "input_ports": ["analysis"],
      "output_ports": ["plan"],
      "parallel_group": null,
      "on_fail": "abort"
    },
    {
      "id": "CP-02",
      "name": "检查点：Registry 方案",
      "type": "checkpoint",
      "description": "在开始批量提取前，review command registry 接口和安全 IPC 命令策略。",
      "auto_continue": false,
      "save_fields": ["session_id", "artifacts", "output_path"]
    },
    {
      "id": "N-003",
      "name": "提取命令元数据",
      "type": "agent",
      "executor": "general-purpose",
      "args_template": "任务：为 {goal} 提取 Maestro CLI 命令元数据。\n\n可用时使用低成本模型或工具：{low_cost_model}。\n\n输入：\n- {maestro_flow_path}\n- maestro --help\n- maestro ralph --help\n- maestro search --help\n- maestro load --help\n\n只交付 JSON 命令条目。明确标记 write / destructive 命令。",
      "input_ports": ["plan"],
      "output_ports": ["command-registry-draft"],
      "parallel_group": null,
      "run_in_background": false,
      "on_fail": "abort"
    },
    {
      "id": "N-004",
      "name": "映射 Superset 概念",
      "type": "agent",
      "executor": "general-purpose",
      "args_template": "任务：把 Superset 概念映射到 Oh My Maestro 产品概念。\n\n不要建议在 MVP 中嵌入 Superset runtime。\n\n交付一张表，把 dashboard、chart、dataset、explore、saved query、filter state 映射到 Maestro 产品等价概念。",
      "input_ports": ["requirement"],
      "output_ports": ["concept-map"],
      "parallel_group": null,
      "run_in_background": false,
      "on_fail": "abort"
    },
    {
      "id": "CP-03",
      "name": "检查点：生成草案 Review",
      "type": "checkpoint",
      "description": "在实现前，由 Codex 或 Claude Code review 低成本模型生成的 registry 和 Superset 概念映射。",
      "auto_continue": false,
      "save_fields": ["artifacts", "output_path"]
    },
    {
      "id": "N-005",
      "name": "实现 Registry 驱动 UI",
      "type": "skill",
      "executor": "maestro-execute",
      "args_template": "在 {target_app_path} 实现已 review 的 command registry 和 registry-driven UI。使用来自 {prev_output_path} 的已 review 产物。",
      "input_ports": ["command-registry-draft", "concept-map"],
      "output_ports": ["code"],
      "parallel_group": null,
      "on_fail": "abort"
    },
    {
      "id": "N-006",
      "name": "验证产品壳",
      "type": "skill",
      "executor": "quality-test",
      "args_template": "验证 {target_app_path} 的 command registry、IPC 白名单、workflow state fallback 和桌面构建。",
      "input_ports": ["code"],
      "output_ports": ["test-passed"],
      "parallel_group": null,
      "on_fail": "abort"
    },
    {
      "id": "N-007",
      "name": "Review 集成风险",
      "type": "skill",
      "executor": "quality-review",
      "args_template": "Review {target_app_path} 的安全性、命令白名单、生成元数据质量和产品边界。",
      "input_ports": ["code"],
      "output_ports": ["review-findings"],
      "parallel_group": null,
      "on_fail": "abort"
    }
  ],
  "edges": [
    { "from": "N-001", "to": "CP-01" },
    { "from": "CP-01", "to": "N-002" },
    { "from": "N-002", "to": "CP-02" },
    { "from": "CP-02", "to": "N-003" },
    { "from": "CP-02", "to": "N-004" },
    { "from": "N-003", "to": "CP-03" },
    { "from": "N-004", "to": "CP-03" },
    { "from": "CP-03", "to": "N-005" },
    { "from": "N-005", "to": "N-006" },
    { "from": "N-006", "to": "N-007" }
  ],
  "checkpoints": ["CP-01", "CP-02", "CP-03"],
  "execution_mode": "serial",
  "metadata": {
    "node_count": 10,
    "checkpoint_count": 3
  }
}
