 	return router({
 		getStatus: publicProcedure
 			.input(
 				z.object({
-					cwd: z.string(),
+					cwd: z.string().min(1).refine(
+						(val) => {
+							const resolved = resolve(val);
+							const normalized = normalize(val);
+							return resolved === normalized && normalized.length > 0;
+						},
+						{ message: "Invalid working directory path" },
+					),
 				}),
 			)
